NODE_ENV=production
LOG_LEVEL=info

APP_ROOT=/opt/apps/certistock
SHARED_ROOT=/opt/apps/certistock/shared
BACKUP_ROOT=/opt/backups/certistock
ARCHIVE_ROOT=/opt/backups/certistock/archive
DATA_ROOT=/srv/certistock/data

LOCAL_API_HOST=127.0.0.1
LOCAL_API_PORT=8787
DATABASE_URL=postgres://certistock_app:CHANGE_ME@127.0.0.1:5432/certistock_utf8
DB_POOL_SIZE=20

JWT_SECRET=CHANGE_ME_GENERATE_48_BYTES_OR_MORE
JWT_EXPIRES_IN=12h

FILE_STORAGE_ROOT=/srv/certistock/data/files
OCR_WORKER_URL=http://127.0.0.1:8001
OCR_WORKER_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY_ONLY_IF_WORKER_IS_LOCALHOST_ONLY
OCR_WORKER_REQUIRED=true
